# .env.example
# Copy to .env.local — never commit secrets

# ── API ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://www.outpro.india/api/v1

# ── Sanity CMS ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_read_token

# ── reCAPTCHA v3 ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_MIN_SCORE=0.5

# ── Supabase Storage ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# ── ISR Webhook ───────────────────────────────────────────────────────────────
REVALIDATION_SECRET=your_revalidation_secret_32chars

# ── JWT (for Edge middleware) ─────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_64chars

# ── Analytics ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
