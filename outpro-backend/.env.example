# .env.example
# Copy to .env.local for development — never commit real secrets

# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_VERSION=v1

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: postgresql://outpro:outpro_dev_password@localhost:5432/outpro_india
# Production: use Supabase connection string
DATABASE_URL=postgresql://outpro:outpro_dev_password@localhost:5432/outpro_india
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false  # Set to true for Supabase

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64_at_least_64_chars_required
JWT_EXPIRY=8h
SESSION_MAX_AGE_SECONDS=28800

# ── Google reCAPTCHA v3 ───────────────────────────────────────────────────────
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_from_google_console
RECAPTCHA_MIN_SCORE=0.5

# ── CMS ISR Webhook ───────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
REVALIDATION_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# ── Email — Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@outpro.india
EMAIL_ADMIN_NOTIFY=leads@outpro.india

# ── CRM (optional) ────────────────────────────────────────────────────────────
# HUBSPOT_API_KEY=pat-na1-your_hubspot_private_app_token
# ZOHO_CLIENT_ID=your_zoho_client_id
# ZOHO_CLIENT_SECRET=your_zoho_client_secret

# ── Upstash Redis (optional in dev — falls back to in-memory) ─────────────────
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Supabase Storage ──────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_STORAGE_BUCKET_PRIVATE=media-private
SUPABASE_STORAGE_BUCKET_PUBLIC=media-public

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://outpro.india,https://www.outpro.india

# ── Bcrypt ────────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Rate Limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MIN=10
RATE_LIMIT_PUBLIC_PER_MIN=100
RATE_LIMIT_AUTHED_PER_MIN=1000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=logs
