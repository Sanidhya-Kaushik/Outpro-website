# ── MongoDB Connection ─────────────────────────────────────────────────────────

# Local development
MONGODB_URI=mongodb://localhost:27017/outpro_india

# MongoDB Atlas (production) — replace with your cluster string
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/outpro_india?retryWrites=true&w=majority

# ── Database name (used by Mongoose dbName option) ─────────────────────────────
MONGODB_DB_NAME=outpro_india

# ── Node environment ───────────────────────────────────────────────────────────
NODE_ENV=development
